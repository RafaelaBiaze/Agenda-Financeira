{
  "compilerOptions": {
    /* --- Básico e Versão --- */
    "target": "ESNext",                         // Define para qual versão do JavaScript o código será convertido (ESNext é a mais moderna).
    "module": "NodeNext",                       // Diz ao TS que estamos usando o sistema de módulos mais novo do Node (permite o uso de imports modernos).
    "moduleResolution": "NodeNext",             // Define como o TS deve procurar os arquivos (essencial para reconhecer o .js nos imports).

    /* --- Organização de Pastas --- */
    "rootDir": "./",                            // Define a raiz do projeto (como o knexfile está na raiz, precisamos que o TS olhe para cá).
    "outDir": "./dist",                         // Pasta onde o código final (JavaScript puro) será jogado após a compilação.

    /* --- Compatibilidade e Segurança --- */
    "esModuleInterop": true,                    // Permite importar bibliotecas que não seguem o padrão ESM (como algumas libs mais antigas).
    "forceConsistentCasingInFileNames": true,   // Evita erros se você escrever "Arquivo.ts" e tentar importar como "arquivo.ts" (comum no Windows).
    
    /* --- Rigor e Qualidade --- */
    "strict": true,                             // Ativa todas as verificações de segurança. O TS fica rigido, mas o código fica muito mais seguro.
    "skipLibCheck": true                        // Ignora a checagem de tipos dentro da pasta node_modules (deixa o processo muito mais rápido).
  },

  /* --- O que o TypeScript deve olhar --- */
  "include": [
    "src/**/*",                                 // Inclui tudo que estiver dentro da pasta src.
    "knexfile.ts"                               // Inclui especificamente o arquivo de configuração do banco.
  ],

  /* --- O que o TypeScript deve ignorar --- */
  "exclude": [
    "node_modules",                             // Ignora as bibliotecas instaladas (não precisamos compilar o código dos outros).
    "dist"                                      // Ignora a pasta de saída para não entrar em um loop infinito de compilação.
  ]
}