# Dependências (Nunca enviar, são pesadas e instaladas via npm install)
node_modules/
package-lock.json

# Compilação do TypeScript (Arquivos JS gerados a partir do TS)
dist/
build/
out/
*.tsbuildinfo

# Variáveis de Ambiente (Segurança: contém senhas do banco de dados)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs (Arquivos de erro e registos do sistema)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Docker (Arquivos de persistência de dados do banco se mapeados em pastas)
pgdata/
docker-volumes/

# Configurações de Editores
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj

# Sistema Operativo
.DS_Store
Thumbs.db